# .env.example — TEMPLATE FILE
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to version control.
# Add .env to your .gitignore immediately.
# cp .env.example .env

# ── Alpaca Markets ──────────────────────────────────────────────
# Get from: https://app.alpaca.markets → API Keys
# Use paper trading keys while testing — never live keys in dev
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Paper trading base URL (use this during development)
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets
# The AlpacaAdapter checks if "paper" is in this URL to set paper=True
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Polymarket ───────────────────────────────────────────────────
# Get from: https://polymarket.com → Profile → API Keys
# POLYMARKET_PRIVATE_KEY is your Polygon wallet private key
# NEVER commit a real private key to version control
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY=

# Polygon RPC URL — used for on-chain transaction signing
# Free public RPC: https://polygon-rpc.com
# Recommended: get a free key from https://www.alchemy.com
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Database ─────────────────────────────────────────────────────
# Path to the SQLite database file — relative to project root
# Do NOT include sqlite:/// prefix — config.py handles that
# The file will be created automatically on first run
DB_PATH=./trading_bot.db

# ── Model Persistence ────────────────────────────────────────────
# Path where the trained PPO model is saved and loaded from
# The feature scaler (feature_scaler.pkl) is saved in the same directory
# Directory is created automatically if it does not exist
MODEL_SAVE_PATH=./models/ppo_agent.zip

# ── Logging ──────────────────────────────────────────────────────
# Python logging level for the root logger
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG during development, INFO in production
LOG_LEVEL=INFO

# ── Trading Constants ────────────────────────────────────────────
# Starting capital in USD — used for position sizing and
# capital_ratio calculation in the RL observation vector.
# CRITICAL: This value must match the initial_capital used during
# training. Changing it after training without retraining the agent
# will cause the capital_ratio observation to be out-of-distribution
# and produce garbage predictions.
INITIAL_CAPITAL=10000.0

# Maximum fraction of capital to risk per trade (0.0 to 1.0)
# 0.2 = risk at most 20% of available capital on any single trade
MAX_POSITION_SIZE=0.2

# Maximum allowed daily drawdown before circuit breaker halts trading
# 0.05 = halt if portfolio drops more than 5% from day-start value
MAX_DAILY_DRAWDOWN=0.05
